# Supabase — get these from supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Database — use Transaction pooler URL from Supabase → Settings → Database → Connection string (port 5432)
DATABASE_URL=postgresql://postgres.xxxx:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Anthropic — from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# App config
NODE_ENV=production
SKIP_DB_INIT=true

# Local dev only (not needed on Vercel)
PORT=3000
